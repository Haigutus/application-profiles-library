        sh:message      "One of the following does not conform: 1) The value type shall be IRI; 2) The value type shall be an instance of the class: nc:PowerBidSchedule" ;
        sh:name         "PowerBidDependency.MainPowerBidSchedule-valueType" ;
        sh:nodeKind     sh:IRI ;
        sh:order        0 ;
        sh:path         ( nc:PowerBidDependency.MainPowerBidSchedule rdf:type ) ;
        sh:severity     sh:Violation .

