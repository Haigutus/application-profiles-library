        sh:maxCount     1 ;
        sh:message      "Cardinality violation. Upper bound shall be 1" ;
        sh:name         "Model.description-cardinality" ;
        sh:order        31 ;
        sh:path         md:Model.description ;
        sh:severity     sh:Violation .

