ma:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        ma:ProfileClassesGroup;
        sh:in           ( nc:SystemOperator nc:ObservabilityArea cim:IdentifiedObject nc:InfluenceArea nc:MonitoringArea nc:AreaBorderTerminal nc:SensitivityArea cim:PowerSystemResource nc:ContingencyArea cim:Terminal nc:Region nc:SynchronousArea md:FullModel dm:DifferenceModel dcat:Dataset );
