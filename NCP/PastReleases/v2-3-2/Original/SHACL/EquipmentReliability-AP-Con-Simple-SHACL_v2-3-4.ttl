er:DCLine.DCPole-valueType
        rdf:type        sh:PropertyShape;
        sh:class        nc:DCPole;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        er:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: nc:DCPole";
        sh:name         "DCLine.DCPole-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        0;
        sh:path         nc:DCLine.DCPole;
        sh:severity     sh:Violation .

er:DCLine.DCPole-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        er:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "DCLine.DCPole-cardinality";
        sh:order        0;
        sh:path         nc:DCLine.DCPole;
        sh:severity     sh:Violation .

er:DCLine  rdf:type     sh:NodeShape;
        sh:property     er:DCLine.DCPole-valueType , er:DCLine.DCPole-cardinality;
        sh:targetClass  cim:DCLine .

