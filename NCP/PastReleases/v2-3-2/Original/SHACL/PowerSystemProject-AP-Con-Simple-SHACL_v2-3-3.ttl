psp:DifferenceModel.PowerSystemProject-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the inverse direction.";
        sh:group        psp:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "DifferenceModel.PowerSystemProject-cardinality";
        sh:order        0;
        sh:path         [ sh:inversePath  nc:PowerSystemProject.DifferenceModel ];
        sh:severity     sh:Violation .

psp:DifferenceModel.PowerSystemProject-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        psp:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        0;
        sh:path         nc:DifferenceModel.PowerSystemProject;
        sh:severity     sh:Violation .

psp:DifferenceModel.PowerSystemProject-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          psp:DifferenceModel.PowerSystemProject-propertyInverse;
        sh:targetSubjectsOf  nc:DifferenceModel.PowerSystemProject .

