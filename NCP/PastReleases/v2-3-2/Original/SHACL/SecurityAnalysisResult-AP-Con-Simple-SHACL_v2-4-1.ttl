        dcterms:identifier    "urn:uuid59762cfe-e0fd-4888-b9e6-5bb246dc9a72";
        dcterms:issued        "2025-01-05T07:38:57.073792300"^^xsd:dateTime;
        dcterms:language      "en-GB";
