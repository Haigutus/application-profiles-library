sar:RemedialActionApplied
        rdf:type        sh:NodeShape;
        sh:property     sar:RemedialActionApplied.RemedialAction-cardinality , sar:RemedialActionApplied.StageForRemedialActionScheme-valueType , sar:RemedialActionApplied.StageForRemedialActionScheme-cardinality , sar:RemedialActionApplied.mRID-datatype , sar:RemedialActionApplied.mRID-cardinality , sar:RemedialActionApplied.PowerFlowResult-cardinality;
        sh:targetClass  nc:RemedialActionApplied .

