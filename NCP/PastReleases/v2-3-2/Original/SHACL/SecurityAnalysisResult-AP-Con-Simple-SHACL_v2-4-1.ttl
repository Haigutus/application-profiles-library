        owl:versionInfo   "2.4.1"@en;
        dcat:keyword      "SAR";
        dcat:theme        "constraint"@en .

sar:BaseCasePowerFlowResult
        rdf:type        sh:NodeShape;
        sh:property     sar:PowerFlowResult.OperationalLimit-cardinality , sar:PowerFlowResult.isViolation-datatype , sar:PowerFlowResult.isViolation-cardinality , sar:PowerFlowResult.atTime-datatype , sar:PowerFlowResult.atTime-cardinality , sar:PowerFlowResult.valueA-datatype , sar:PowerFlowResult.valueA-cardinality , sar:PowerFlowResult.ReportedByRegion-cardinality , sar:PowerFlowResult.valueAngle-datatype , sar:PowerFlowResult.ACDCTerminal-cardinality , sar:PowerFlowResult.value-cardinality , sar:PowerFlowResult.value-datatype , sar:PowerFlowResult.valueV-cardinality , sar:PowerFlowResult.valueV-datatype , sar:PowerFlowResult.valueW-cardinality , sar:PowerFlowResult.valueW-datatype , sar:PowerFlowResult.valueVAR-cardinality , sar:PowerFlowResult.valueVAR-datatype , sar:PowerFlowResult.valueVA-cardinality , sar:PowerFlowResult.valueVA-datatype , sar:PowerFlowResult.absoluteValue-cardinality , sar:PowerFlowResult.absoluteValue-datatype , sar:PowerFlowResult.valueAngle-cardinality;
        sh:targetClass  nc:BaseCasePowerFlowResult .

sar:Stage.RemedialActionApplied-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        sar:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        0;
        sh:path         nc:Stage.RemedialActionApplied;
        sh:severity     sh:Violation .

sar:Stage.RemedialActionApplied-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          sar:Stage.RemedialActionApplied-propertyInverse;
        sh:targetSubjectsOf  nc:Stage.RemedialActionApplied .

sar:Stage  rdf:type     sh:NodeShape;
        sh:targetClass  nc:Stage .

sar:RemedialActionApplied.RemedialAction-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        sar:AssociationsGroup;
        sh:in           ( nc:SchemeRemedialAction nc:AvailabilityRemedialAction nc:GridStateAlterationRemedialAction nc:RedispatchRemedialAction nc:CountertradeRemedialAction );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "RemedialActionApplied.RemedialAction-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        3;
        sh:path         ( nc:RemedialActionApplied.RemedialAction rdf:type );
        sh:severity     sh:Violation .

sar:RemedialActionApplied.RemedialAction-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     sar:RemedialActionApplied.RemedialAction-valueType;
        sh:targetClass  nc:RemedialActionApplied .

sar:RemedialActionApplied.RemedialAction-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        sar:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "RemedialActionApplied.RemedialAction-cardinality";
        sh:order        3;
        sh:path         nc:RemedialActionApplied.RemedialAction;
        sh:severity     sh:Violation .

sar:RemedialActionApplied.StageForRemedialActionScheme-valueType
        rdf:type        sh:PropertyShape;
        sh:class        nc:Stage;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        sar:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: nc:Stage";
        sh:name         "RemedialActionApplied.StageForRemedialActionScheme-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        2;
        sh:path         nc:RemedialActionApplied.StageForRemedialActionScheme;
        sh:severity     sh:Violation .

sar:RemedialActionApplied.StageForRemedialActionScheme-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        sar:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "RemedialActionApplied.StageForRemedialActionScheme-cardinality";
        sh:order        2;
        sh:path         nc:RemedialActionApplied.StageForRemedialActionScheme;
        sh:severity     sh:Violation .

sar:RemedialActionApplied.mRID-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        sar:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "RemedialActionApplied.mRID-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        1;
        sh:path         nc:RemedialActionApplied.mRID;
        sh:severity     sh:Violation .

sar:RemedialActionApplied.mRID-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        sar:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "RemedialActionApplied.mRID-cardinality";
        sh:order        1;
        sh:path         nc:RemedialActionApplied.mRID;
        sh:severity     sh:Violation .

sar:RemedialActionApplied.PowerFlowResult-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        sar:AssociationsGroup;
        sh:in           ( nc:ContingencyPowerFlowResult nc:BaseCasePowerFlowResult );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
