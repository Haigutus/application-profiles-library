@base          <https://ap-con.cim4.eu/EquipmentReliability-Complex/2.3> .
@prefix erc:  <https://ap-con.cim4.eu/EquipmentReliability-Complex/2.3#> .
@prefix cim:     <https://cim.ucaiug.io/ns#> .
@prefix cim16:   <http://iec.ch/TC57/2013/CIM-schema-cim16#> .
@prefix cim17:   <http://iec.ch/TC57/CIM100#> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ido:     <https://ap-con.cim4.eu/NC-IdentifiedObject/2.3#> .
@prefix nc:      <https://cim4.eu/ns/nc#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix propref:     <https://energy.referencedata.eu/PropertyReference/> .


erc:Ontology  rdf:type         owl:Ontology ;
        dcterms:conformsTo        "urn:iso:std:iec:61970-501:draft:ed-2" , "urn:iso:std:iec:61970-600-2:ed-1" , "urn:iso:std:iec:61970-301:ed-7:amd1" , "file://iec61970cim17v40_iec61968cim13v13a_iec62325cim03v17a.eap" ;
        dcterms:creator           "ENTSO-E CIM EG"@en ;
        dcterms:description       "The custom constraints for the equipment reliability profile."@en ;
        dcterms:identifier        "urn:uuid:f7898d6b-3ffc-4515-8459-95390ae7a9ca" ;
        dcterms:issued            "2025-01-04T12:09:21Z"^^xsd:dateTime ;
        dcterms:language          "en-GB" ;
        dcterms:modified          "2025-01-04"^^xsd:date ;
        dcterms:publisher         "ENTSO-E"@en ;
        dcterms:rights            "Copyright"@en ;
        dcterms:rightsHolder      "ENTSO-E"@en ;
        dcterms:title             "Equipment Reliability profile custom constraints"@en ;
        owl:versionIRI        <https://ap-con.cim4.eu/EquipmentReliability-Complex/2.3> ;
		dcterms:license        "https://www.apache.org/licenses/LICENSE-2.0" ;
        owl:versionInfo       "2.3.2"@en ;
        dcat:landingPage      "https://www.entsoe.eu/digital/cim/cim-for-grid-models-exchange/" ;
        dcat:theme            "constraints"@en .

cim:    
    a           owl:Ontology ;
    owl:imports sh: ;
    sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "https://cim.ucaiug.io/ns#"^^xsd:anyURI ;
        sh:prefix "cim" ;
    ] ;
	sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "http://iec.ch/TC57/2013/CIM-schema-cim16#"^^xsd:anyURI ;
        sh:prefix "cim16" ;
    ] ;
	sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "https://cim4.eu/ns/nc#"^^xsd:anyURI ;
        sh:prefix "nc" ;
    ] ;
    sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "http://www.w3.org/1999/02/22-rdf-syntax-ns#"^^xsd:anyURI ;
        sh:prefix "rdf" ;
    ] ;
    sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "http://iec.ch/TC57/CIM100#"^^xsd:anyURI ;
        sh:prefix "cim17" ;
    ] .


erc:ERgroup
        a           sh:PropertyGroup ;
        rdfs:label  "EquipmentReliabilityGroup" ;
        sh:order    0 .
		

erc:AreaDispatchableUnit  a          sh:NodeShape ;
        sh:property      erc:AreaDispatchableUnit-associations;
        sh:targetClass  nc:AreaDispatchableUnit .



erc:AreaDispatchableUnit-associations
        a               sh:PropertyShape ;
        sh:description  "The AreaDispatchableUnit shall be associated with either GeneratingUnit, PowerElecronicsUnit, EnergyConsumer, ScheduleResource or HydroPump." ;
        sh:sparql       erc:AreaDispatchableUnit-associationsSparql ;
        sh:path         rdf:type ;
        sh:group        erc:ERgroup ;
        sh:name         "C:NC:ER:AreaDispatchableUnit:associations" ;
        sh:order        1 ;
        sh:severity     sh:Violation .
        
erc:AreaDispatchableUnit-associationsSparql
		a         sh:SPARQLConstraint ;  
		sh:message      "AreaDispatchableUnit is not associated with either GeneratingUnit, PowerElecronicsUnit, EnergyConsumer, ScheduleResource or HydroPump." ;
		sh:prefixes cim: ;
		sh:select """
			SELECT  $this  
			WHERE {      
       
		BIND(EXISTS{$this nc:AreaDispatchableUnit.GeneratingUnit ?o1} AS ?adugu).
		BIND(EXISTS{$this nc:AreaDispatchableUnit.PowerElecronicsUnit ?o2} AS ?adupe).
		BIND(EXISTS{$this nc:AreaDispatchableUnit.EnergyConsumer ?o3} AS ?aduec).
		BIND(EXISTS{$this nc:AreaDispatchableUnit.ScheduleResource ?o4} AS ?adusr).
		BIND(EXISTS{$this nc:AreaDispatchableUnit.HydroPump ?o5} AS ?aduhp).
        FILTER (?adugu=false && ?adupe=false && ?aduec=false && ?adusr=false && ?aduhp=false).
			}""" . 
			
erc:EnergyComponent  a          sh:NodeShape ;
        sh:property      erc:EnergyComponent-associations;
        sh:targetClass  nc:EnergyComponent .



erc:EnergyComponent-associations
        a               sh:PropertyShape ;
        sh:description  "The EnergyComponent shall be associated with either GeneratingUnit, PowerElecronicsUnit, EnergyConsumer or HydroPump." ;
        sh:sparql       erc:EnergyComponent-associationsSparql ;
        sh:path         rdf:type ;
        sh:group        erc:ERgroup ;
        sh:name         "C:NC:ER:EnergyComponent:associations" ;
        sh:order        2 ;
        sh:severity     sh:Violation .
        
erc:EnergyComponent-associationsSparql
		a         sh:SPARQLConstraint ;  
		sh:message      "EnergyComponent is not associated with either GeneratingUnit, PowerElecronicsUnit, EnergyConsumer or HydroPump." ;
		sh:prefixes cim: ;
		sh:select """
			SELECT  $this  
			WHERE {      
       
		BIND(EXISTS{$this nc:EnergyComponent.GeneratingUnit ?o1} AS ?adugu).
		BIND(EXISTS{$this nc:EnergyComponent.PowerElecronicsUnit ?o2} AS ?adupe).
		BIND(EXISTS{$this nc:EnergyComponent.EnergyConsumer ?o2} AS ?aduec).
		BIND(EXISTS{$this nc:EnergyComponent.HydroPump ?o2} AS ?aduhp).
        FILTER (?adugu=false && ?adupe=false && ?aduec=false && ?aduhp=false).
			}""" . 			
			
			
erc:HydroPowerPlant  a          sh:NodeShape ;
        sh:property      erc:HydroPowerPlant-operatingMode;
        sh:targetClass  cim:HydroPowerPlant, cim16:HydroPowerPlant, cim17:HydroPowerPlant .			
		
erc:HydroPowerPlant-operatingMode
        a               sh:PropertyShape ;
        sh:description  "The SynchronousMachine.operatingMode of all SynchronousMachine objects part of a HydroPowerPlant shall be consistent." ;
        sh:sparql       erc:HydroPowerPlant-operatingModeSparql ;
        sh:path         rdf:type ;
        sh:group        erc:ERgroup ;
        sh:name         "C:NC:ER:HydroPowerPlant:operatingMode" ;
        sh:order        3 ;
        sh:severity     sh:Violation .
        
erc:HydroPowerPlant-operatingModeSparql
		a         sh:SPARQLConstraint ;  
		sh:message      "The SynchronousMachine.operatingMode is not consistent for all SynchronousMachine objects part of a HydroPowerPlant." ;
		sh:prefixes cim: ;
		sh:select """
	      SELECT $this (COUNT(?value) AS ?countv)
        WHERE {
        $this ^cim16:HydroGeneratingUnit.HydroPowerPlant/^cim16:RotatingMachine.GeneratingUnit/cim16:SynchronousMachine.operatingMode|^cim17:HydroGeneratingUnit.HydroPowerPlant/^cim17:RotatingMachine.GeneratingUnit/cim17:SynchronousMachine.operatingMode|^cim:HydroGeneratingUnit.HydroPowerPlant/^cim:RotatingMachine.GeneratingUnit/cim:SynchronousMachine.operatingMode|^cim16:HydroPump.HydroPowerPlant/cim16:HydroPump.RotatingMachine/cim16:SynchronousMachine.operatingMode|^cim17:HydroPump.HydroPowerPlant/cim17:HydroPump.RotatingMachine/cim17:SynchronousMachine.operatingMode|^cim:HydroPump.HydroPowerPlant/cim:HydroPump.RotatingMachine/cim:SynchronousMachine.operatingMode ?value .
        }
        GROUP BY $this ?value
        HAVING(?countv>1)
      """ .    

erc:Circuit  a          sh:NodeShape ;
        sh:property      erc:Circuit-associations;
        sh:targetClass  nc:LineCircuit, nc:PowerTransformerCircuit .



erc:Circuit-associations
        a               sh:PropertyShape ;
        sh:description  "The Circuit shall be associated with either Equipment or Terminal." ;
        sh:sparql       erc:Circuit-associationsSparql ;
        sh:path         rdf:type ;
        sh:group        erc:ERgroup ;
        sh:name         "C:NC:ER:Circuit:associations" ;
        sh:order        4 ;
        sh:severity     sh:Violation .
        
erc:Circuit-associationsSparql
		a         sh:SPARQLConstraint ;  
		sh:message      "Circuit is not associated with either Equipment or Terminal." ;
		sh:prefixes cim: ;
		sh:select """
			SELECT  $this  
			WHERE {      
       
		BIND(EXISTS{$this nc:Circuit.Equipment ?o1} AS ?ce).
		BIND(EXISTS{$this nc:Circuit.IdentifyingTerminal ?o2} AS ?ct).
        FILTER (?ce=false && ?ct=false).
			}""" . 		
			
erc:FunctionOutputVariable  a          sh:NodeShape ;
        sh:property      erc:FunctionOutputVariable.PropertyReference-value;
        sh:targetClass  nc:FunctionOutputVariable .



erc:FunctionOutputVariable.PropertyReference-value
        a               sh:PropertyShape ;
        sh:description  "The value of the association end FunctionOutputVariable.PropertyReference shall be one of the values published in the skos:ConceptScheme  https://energy.referencedata.eu/PropertyReference/." ;
        sh:message      "The value of the PropertyReference is not part of the reference data." ;
        sh:path         nc:FunctionOutputVariable.PropertyReference ;
		sh:in			(propref:ACDCConverter.p propref:ACDCConverter.q propref:ACDCConverter.targetPpcc propref:ACDCConverter.targetUdc propref:ACDCTerminal.connected propref:ActivePowerControlFunction.targetValue propref:ActivePowerLimit.value propref:ApparentPowerLimit.value propref:AreaDispatchableUnit.enabled propref:AssessedElement.enabled propref:AssessedElement.maxFlow propref:AssessedElement.maxMarginAdjustment propref:AssessedElement.positiveVirtualMargin propref:AssessedElement.scannedThresholdMargin propref:AssessedElementWithContingency.enabled propref:AssessedElementWithRemedialAction.enabled propref:AsynchronousMachine.asynchronousMachineType propref:BatteryUnit.batteryState propref:BatteryUnit.storedE propref:BiddingZone.netPosition propref:BiddingZoneBorder.alreadyAllocatedCapacity propref:BiddingZoneBorder.alreadyAllocatedFlow propref:BiddingZoneBorder.availableTransferCapacity propref:BiddingZoneBorder.netTransferCapacity propref:BiddingZoneBorder.totalTransferCapacity propref:BiddingZoneBorder.transmissionReliabilityMargin propref:CircuitShare.contributionFactor propref:CompensatorController.mode propref:Contingency.mustStudy propref:Contingency.probability propref:ContingencyWithRemedialAction.enabled propref:ControlArea.netInterchange propref:ControlArea.pTolerance propref:CsConverter.operatingMode propref:CsConverter.pPccControl propref:CsConverter.targetAlpha propref:CsConverter.targetGamma propref:CsConverter.targetIdc propref:CurrentControlFunction.targetValue propref:CurrentDroopControlFunction.targetValueCapacitive propref:CurrentDroopControlFunction.targetValueInductive propref:CurrentDroopOverride.enabled propref:DCCurrentControlFunction.targetValue propref:DCPole.maxEconomicP propref:DCPole.minEconomicP propref:DCSwitch.locked propref:DCSwitch.open propref:DCTieCorridor.p propref:DCTieCorridor.q propref:DCVoltageControlFunction.targetValue propref:EnergyBlockOrder.participationFactor propref:EnergyConsumer.p propref:EnergyConsumer.participationFactor propref:EnergyConsumer.q propref:EnergyGroup.participationFactor propref:EnergySource.activePower propref:EnergySource.reactivePower propref:EnergySource.voltageAngle propref:EnergySource.voltageMagnitude propref:Equipment.inService propref:Equipment.networkAnalysisEnabled propref:EquivalentInjection.p propref:EquivalentInjection.q propref:EquivalentInjection.regulationStatus propref:EquivalentInjection.regulationTarget propref:ExternalNetworkInjection.p propref:ExternalNetworkInjection.q propref:ExternalNetworkInjection.referencePriority propref:FACTSEquipment.q propref:FuelStorage.energyStorage propref:FunctionBlock.enabled propref:GeneratingUnit.normalPF propref:GeneratingUnit.participationFactor propref:GridStateAlteration.enabled propref:GridStateAlteration.participationFactor propref:HydroPump.participationFactor propref:ImpedanceControlFunction.targetValue propref:InfeedLimit.valueA propref:InfeedLimit.valueW propref:InjectionController.mode propref:PhaseControlFunction.targetValue propref:PowerElectronicsConnection.p propref:PowerElectronicsConnection.q propref:PowerElectronicsUnit.participationFactor propref:PowerFactorControlFunction.targetValue propref:PowerRemedialAction.maxRegulatingDown propref:PowerRemedialAction.maxRegulatingUp propref:PowerTransferCorridor.enabled propref:PTCActivePowerSupport.value propref:RangeConstraint.value propref:ReactivePowerControlFunction.targetValue propref:RegulatingCondEq.controlEnabled propref:RegulatingControl.discrete propref:RegulatingControl.enabled propref:RegulatingControl.maxAllowedTargetValue propref:RegulatingControl.minAllowedTargetValue propref:RegulatingControl.targetDeadband propref:RegulatingControl.targetValue propref:RegulatingControl.targetValueUnitMultiplier propref:RemedialAction.available propref:RemedialActionDependency.enabled propref:RemedialActionGroup.maxRegulatingDown propref:RemedialActionGroup.maxRegulatingUp propref:RemedialActionScheme.armed propref:RemedialActionScheme.inService propref:Reservoir.energyStorage propref:RotatingMachine.p propref:RotatingMachine.q propref:RotatingMachineController.mode propref:ScheduleResource.participationFactor propref:ShuntCompensator.sections propref:SSSCController.mode propref:StageTrigger.armed propref:StaticVarCompensator.q propref:SubstationController.mode propref:Switch.locked propref:Switch.open propref:SynchronousMachine.operatingMode propref:SynchronousMachine.referencePriority propref:TapChanger.controlEnabled propref:TapChanger.step propref:TCSCController.mode propref:VoltageAngleLimit.value propref:VoltageControlFunction.targetValue propref:VoltageInjectionControlFunction.targetValue propref:VoltageLimit.value propref:VsConverter.droop propref:VsConverter.droopCompensation propref:VsConverter.pPccControl propref:VsConverter.qPccControl propref:VsConverter.qShare propref:VsConverter.targetPhasePcc propref:VsConverter.targetPowerFactorPcc propref:VsConverter.targetPWMfactor propref:VsConverter.targetQpcc propref:VsConverter.targetUpcc propref:GeneratingUnit.startupCost propref:ThyristorControlledSeriesCompensator.currentSection propref:EnergyGroup.p propref:GeneratingUnit.warmStartupCost propref:ACEmulationControlFunction.timeConstant propref:ACEmulationControlFunction.referenceP propref:EnergyBlockOrder.sequence propref:AssessedElement.coordinatedValidationAdjustmentJustification propref:DCPole.participationFactor propref:AssessedElement.targetRemainingAvailableMarginJustification propref:PowerCapacity.netACInterchange propref:PowerCapacity.minInterchange propref:PowerCapacity.maxInterchange propref:AssessedElement.individualValidationAdjustmentShare propref:DCPole.p propref:CurrentDroopOverride.targetValueCapacitiveI propref:AssessedElement.coordinatedValidationAdjustment propref:PowerCapacity.netACInterchangeTolerance propref:AreaDispatchableUnit.p propref:ScheduleResource.p propref:PowerCapacity.netDCInterchange propref:PowerShiftKeyStrategy.enabled propref:StageTrigger.inService propref:FrequencyControlFunction.frequencyBias propref:GeneratingUnit.mustRun propref:AssessedElement.individualValidationAdjustment propref:SchedulingArea.p propref:PowerElectronicsUnit.p propref:PowerShiftKeyStrategy.participationFactor propref:PowerCapacity.regulatingUpAllocation propref:AssessedElement.individualValidationAdjustmentJustification propref:PowerCapacity.regulatingDownAllocation propref:CrossBorderRelevance.enabled propref:CurrentDroopOverride.targetValueInductiveI propref:DirectCurrentEquipmentController.mode propref:AutomationFunction.enabled propref:AssessedElement.criticalElementContingencyJustification propref:PowerCapacity.minImportP propref:GeneratingUnit.mustRunQ propref:GeneratingUnit.mustRunP propref:FrequencyControlFunction.targetValue propref:EnergyBlockOrder.p propref:AssessedElement.appointedMargin propref:ThyristorControlledSeriesCompensator.compensationZ propref:SchedulingArea.participationFactor propref:ACEmulationControlFunction.gain  );
        sh:group        erc:ERgroup ;
        sh:name         "C:NC:ER:FunctionOutputVariable.PropertyReference:value" ;
        sh:order        5 ;
        sh:severity     sh:Violation .			