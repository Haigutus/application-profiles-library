iam:Ontology  rdf:type    owl:Ontology;
        dcterms:conformsTo    "urn:iso:std:iec:61970-401:draft:ed-1" , "urn:iso:std:iec:61970-301:ed-7:amd1" , "file://iec61970cim17v40_iec61968cim13v13a_iec62325cim03v17a.eap" , "urn:iso:std:iec:61970-501:draft:ed-2" , "file://CIM100_CGMES31v01_501-20v02_NC23v62_MM10v01.eap" , "urn:iso:std:iec:61970-600-2:ed-1";
        dcterms:description   "Describing constraints extracted from RDFS.";
        dcterms:identifier    "urn:uuid06cc97a3-e1de-4573-9b29-5504cdca9ca1";
        dcterms:issued        "2025-01-05T07:36:58.666452400"^^xsd:dateTime;
        dcterms:language      "en-GB";
