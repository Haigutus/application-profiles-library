		<dcterms:format rdf:resource="https://www.iana.org/assignments/media-types/application/rdf+xml"/>
		<dcterms:title>Dataset metadata Vocabulary</dcterms:title>
		<dcterms:description>Vocabulary for the Dataset metadata profile. It is the RDFS.</dcterms:description>
