        sh:property     ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.energyIdentCodeEic-datatype , ido:IdentifiedObject.energyIdentCodeEic-cardinality , ido:IdentifiedObject.shortName-datatype , ido:IdentifiedObject.shortName-cardinality , ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality;
        sh:targetClass  cim:GeographicalRegion .

eqbd:Terminal.ConductingEquipment-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        eqbd:AssociationsGroup;
        sh:in           ( cim:Junction cim:BusbarSection cim:EnergyConsumer cim:ConformLoad cim:StationSupply cim:NonConformLoad cim:GroundingImpedance cim:PetersenCoil cim:LinearShuntCompensator cim:NonlinearShuntCompensator cim:ExternalNetworkInjection cim:AsynchronousMachine cim:SynchronousMachine cim:StaticVarCompensator cim:Ground cim:SeriesCompensator cim:ACLineSegment cim:VsConverter cim:CsConverter cim:PowerTransformer cim:EnergySource cim:EquivalentBranch cim:EquivalentInjection cim:EquivalentShunt cim:Switch cim:Disconnector cim:Breaker cim:LoadBreakSwitch cim:GroundDisconnector );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "Terminal.ConductingEquipment-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        1;
        sh:path         ( cim:Terminal.ConductingEquipment rdf:type );
        sh:severity     sh:Violation .

eqbd:Terminal.ConductingEquipment-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     eqbd:Terminal.ConductingEquipment-valueType;
        sh:targetClass  cim:Terminal .

eqbd:Terminal.ConductingEquipment-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        eqbd:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "Terminal.ConductingEquipment-cardinality";
        sh:order        1;
        sh:path         cim:Terminal.ConductingEquipment;
        sh:severity     sh:Violation .

eqbd:Terminal-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              eqbd:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              1;
        sh:property           [ sh:path  cim:Terminal.ConductingEquipment ];
        sh:severity           sh:Info;
        sh:targetClass        cim:Terminal .

eqbd:Terminal  rdf:type  sh:NodeShape;
        sh:property     eqbd:Terminal.ConductingEquipment-cardinality;
        sh:targetClass  cim:Terminal .

eqbd:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        eqbd:ProfileClassesGroup;
        sh:in           ( cim:Terminal cim:GeographicalRegion entsoe:EnergySchedulingType cim:BaseVoltage cim:Line cim:ConnectivityNode cim:SubGeographicalRegion cim:DCSeriesDevice cim:DCLineSegment cim:DCBusbar cim:DCShunt cim:DCChopper cim:DCGround cim:DCSwitch cim:DCDisconnector cim:DCBreaker cim:GeneratingUnit cim:SolarGeneratingUnit cim:ThermalGeneratingUnit cim:WindGeneratingUnit cim:NuclearGeneratingUnit cim:HydroGeneratingUnit cim:HydroPump cim:BusbarSection cim:Junction cim:EnergyConsumer cim:ConformLoad cim:StationSupply cim:NonConformLoad cim:GroundingImpedance cim:PetersenCoil cim:LinearShuntCompensator cim:NonlinearShuntCompensator cim:ExternalNetworkInjection cim:AsynchronousMachine cim:SynchronousMachine cim:StaticVarCompensator cim:Ground cim:SeriesCompensator cim:ACLineSegment cim:VsConverter cim:CsConverter cim:PowerTransformer cim:EnergySource cim:EquivalentBranch cim:EquivalentInjection cim:EquivalentShunt cim:Switch cim:Disconnector cim:Breaker cim:LoadBreakSwitch cim:GroundDisconnector md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

