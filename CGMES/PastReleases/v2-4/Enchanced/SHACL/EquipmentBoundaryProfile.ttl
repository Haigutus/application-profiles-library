eqbd:Equipment.EquipmentContainer-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        eqbd:AssociationsGroup;
        sh:in           ( cim:Line cim:DCEquipmentContainer cim:DCConverterUnit cim:DCLine cim:Substation cim:VoltageLevel cim:Bay );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "Equipment.EquipmentContainer-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        5;
        sh:path         ( cim:Equipment.EquipmentContainer rdf:type );
        sh:severity     sh:Violation .

eqbd:Equipment.EquipmentContainer-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     eqbd:Equipment.EquipmentContainer-valueType;
        sh:targetClass  cim:Junction .

eqbd:Equipment.EquipmentContainer-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        eqbd:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "Equipment.EquipmentContainer-cardinality";
        sh:order        49;
        sh:path         cim:Equipment.EquipmentContainer;
        sh:severity     sh:Violation .

eqbd:ConductingEquipment.Terminals-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        eqbd:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        6;
        sh:path         cim:ConductingEquipment.Terminals;
        sh:severity     sh:Violation .

eqbd:ConductingEquipment.Terminals-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          eqbd:ConductingEquipment.Terminals-propertyInverse;
        sh:targetSubjectsOf  cim:ConductingEquipment.Terminals .

eqbd:Junction-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              eqbd:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              8;
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  entsoe:IdentifiedObject.energyIdentCodeEic ];
        sh:property           [ sh:path  entsoe:IdentifiedObject.shortName ];
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:Equipment.EquipmentContainer ];
        sh:severity           sh:Info;
        sh:targetClass        cim:Junction .

eqbd:Junction  rdf:type  sh:NodeShape;
        sh:property     ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.energyIdentCodeEic-datatype , ido:IdentifiedObject.energyIdentCodeEic-cardinality , ido:IdentifiedObject.shortName-datatype , ido:IdentifiedObject.shortName-cardinality , ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , eqbd:Equipment.EquipmentContainer-cardinality;
        sh:targetClass  cim:Junction .

