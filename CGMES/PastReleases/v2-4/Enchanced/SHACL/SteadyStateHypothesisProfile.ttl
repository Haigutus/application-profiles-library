ssh:HydroGeneratingUnit-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              ssh:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              36;
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:GeneratingUnit.normalPF ];
        sh:severity           sh:Info;
        sh:targetClass        cim:HydroGeneratingUnit .

ssh:HydroGeneratingUnit
        rdf:type        sh:NodeShape;
        sh:property     ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , ssh:GeneratingUnit.normalPF-datatype , ssh:GeneratingUnit.normalPF-cardinality;
        sh:targetClass  cim:HydroGeneratingUnit .

ssh:CsConverter.operatingMode-datatype
