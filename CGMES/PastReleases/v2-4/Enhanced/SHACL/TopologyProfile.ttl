        sh:targetSubjectsOf  cim:DCTopologicalNode.DCNodes .

tp:DCTopologicalNode-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              tp:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              7;
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  entsoe:IdentifiedObject.energyIdentCodeEic ];
        sh:property           [ sh:path  entsoe:IdentifiedObject.shortName ];
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:DCTopologicalNode.DCEquipmentContainer ];
        sh:severity           sh:Info;
        sh:targetClass        cim:DCTopologicalNode .

tp:DCTopologicalNode  rdf:type  sh:NodeShape;
        sh:property     ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.energyIdentCodeEic-datatype , ido:IdentifiedObject.energyIdentCodeEic-cardinality , ido:IdentifiedObject.shortName-datatype , ido:IdentifiedObject.shortName-cardinality , ido:IdentifiedObject.description-datatype , ido:IdentifiedObject.description-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , tp:DCTopologicalNode.DCEquipmentContainer-cardinality;
