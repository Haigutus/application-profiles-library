tp:DCTopologicalNode.DCTerminals-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        tp:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        4;
        sh:path         cim:DCTopologicalNode.DCTerminals;
        sh:severity     sh:Violation .

tp:DCTopologicalNode.DCTerminals-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          tp:DCTopologicalNode.DCTerminals-propertyInverse;
        sh:targetSubjectsOf  cim:DCTopologicalNode.DCTerminals .

tp:DCTopologicalNode.DCEquipmentContainer-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        tp:AssociationsGroup;
        sh:in           ( cim:DCConverterUnit cim:DCLine );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "DCTopologicalNode.DCEquipmentContainer-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        9;
        sh:path         ( cim:DCTopologicalNode.DCEquipmentContainer rdf:type );
        sh:severity     sh:Violation .

tp:DCTopologicalNode.DCEquipmentContainer-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     tp:DCTopologicalNode.DCEquipmentContainer-valueType;
        sh:targetClass  cim:DCTopologicalNode .

tp:DCTopologicalNode.DCEquipmentContainer-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        tp:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "DCTopologicalNode.DCEquipmentContainer-cardinality";
        sh:order        33;
        sh:path         cim:DCTopologicalNode.DCEquipmentContainer;
        sh:severity     sh:Violation .

tp:DCTopologicalNode.DCNodes-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        tp:InverseAssociationsGroup;
