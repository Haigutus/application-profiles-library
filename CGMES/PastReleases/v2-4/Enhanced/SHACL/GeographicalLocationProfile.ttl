@base   <http://entsoe.eu/CIM/GeographicalLocation/2/1/Constraints> .
@prefix cim:  <http://iec.ch/TC57/2013/CIM-schema-cim16#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dm:   <http://iec.ch/TC57/61970-552/DifferenceModel/1#> .
@prefix gl:   <http://entsoe.eu/CIM/GeographicalLocation/2/1/Constraints#> .
@prefix ido:  <http://iec.ch/TC57/ns/CIM/IdentifiedObject/constraints/3.0#> .
@prefix md:   <http://iec.ch/TC57/61970-552/ModelDescription/1#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

gl:Location.CoordinateSystem-valueType
        rdf:type        sh:PropertyShape;
        sh:class        cim:CoordinateSystem;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        gl:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: cim16:CoordinateSystem";
        sh:name         "Location.CoordinateSystem-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        3;
        sh:path         cim:Location.CoordinateSystem;
        sh:severity     sh:Violation .

gl:Location.CoordinateSystem-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        gl:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "Location.CoordinateSystem-cardinality";
        sh:order        12;
        sh:path         cim:Location.CoordinateSystem;
        sh:severity     sh:Violation .

gl:Location.PowerSystemResources-valueType
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        gl:AssociationsGroup;
        sh:in           ( cim:ControlArea cim:HydroPowerPlant cim:DCSeriesDevice cim:DCLineSegment cim:DCBusbar cim:DCShunt cim:DCChopper cim:DCGround cim:DCSwitch cim:DCDisconnector cim:DCBreaker cim:GeneratingUnit cim:SolarGeneratingUnit cim:ThermalGeneratingUnit cim:WindGeneratingUnit cim:NuclearGeneratingUnit cim:HydroGeneratingUnit cim:HydroPump cim:BusbarSection cim:Junction cim:EnergyConsumer cim:ConformLoad cim:StationSupply cim:NonConformLoad cim:GroundingImpedance cim:PetersenCoil cim:LinearShuntCompensator cim:NonlinearShuntCompensator cim:ExternalNetworkInjection cim:AsynchronousMachine cim:SynchronousMachine cim:StaticVarCompensator cim:Ground cim:SeriesCompensator cim:ACLineSegment cim:VsConverter cim:CsConverter cim:PowerTransformer cim:EnergySource cim:EquivalentBranch cim:EquivalentInjection cim:EquivalentShunt cim:Switch cim:Disconnector cim:Breaker cim:LoadBreakSwitch cim:GroundDisconnector cim:EquivalentNetwork cim:DCEquipmentContainer cim:DCConverterUnit cim:DCLine cim:Line cim:Substation cim:VoltageLevel cim:Bay cim:RegulatingControl cim:TapChangerControl cim:PhaseTapChangerTabular cim:PhaseTapChangerLinear cim:PhaseTapChangerAsymmetrical cim:PhaseTapChangerSymmetrical cim:RatioTapChanger );
        sh:message      "One of the following occurs: 1) The value is not IRI; 2) The value is not the right class.";
        sh:name         "Location.PowerSystemResources-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        2;
        sh:path         ( cim:Location.PowerSystemResources rdf:type );
        sh:severity     sh:Violation .

gl:Location.PowerSystemResources-valueTypeNodeShape
        rdf:type        sh:NodeShape;
        sh:property     gl:Location.PowerSystemResources-valueType;
        sh:targetClass  cim:Location .

gl:Location.PowerSystemResources-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        gl:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "Location.PowerSystemResources-cardinality";
        sh:order        11;
        sh:path         cim:Location.PowerSystemResources;
        sh:severity     sh:Violation .

gl:Location.PositionPoints-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the inverse direction.";
        sh:group        gl:CardinalityGroup;
        sh:message      "Cardinality violation. Lower bound shall be 1";
        sh:minCount     1;
        sh:name         "Location.PositionPoints-cardinality";
        sh:order        10;
        sh:path         [ sh:alternativePath  ( [ sh:inversePath  cim:PositionPoint.Location ]
                                                [ sh:inversePath  <http://iec.ch/TC57/CIM100#PositionPoint.Location> ]
                                                [ sh:inversePath  <https://cim.ucaiug.io/ns#PositionPoint.Location> ]
                                              )
                        ];
        sh:severity     sh:Violation .

gl:Location.PositionPoints-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        gl:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        2;
        sh:path         cim:Location.PositionPoints;
        sh:severity     sh:Violation .

gl:Location.PositionPoints-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          gl:Location.PositionPoints-propertyInverse;
        sh:targetSubjectsOf  cim:Location.PositionPoints .

gl:Location-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              gl:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              3;
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:Location.CoordinateSystem ];
        sh:property           [ sh:path  cim:Location.PowerSystemResources ];
        sh:severity           sh:Info;
        sh:targetClass        cim:Location .

gl:Location  rdf:type   sh:NodeShape;
        sh:property     ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , gl:Location.CoordinateSystem-valueType , gl:Location.CoordinateSystem-cardinality , gl:Location.PowerSystemResources-cardinality , gl:Location.PositionPoints-cardinality;
        sh:targetClass  cim:Location .

gl:PositionPoint.Location-valueType
        rdf:type        sh:PropertyShape;
        sh:class        cim:Location;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        gl:AssociationsGroup;
        sh:message      "One of the following does not conform: 1) The value shall be IRI; 2) The value shall be an instance of the class: cim16:Location";
        sh:name         "PositionPoint.Location-valueType";
        sh:nodeKind     sh:IRI;
        sh:order        1;
        sh:path         cim:PositionPoint.Location;
        sh:severity     sh:Violation .

gl:PositionPoint.Location-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the association at the used direction.";
        sh:group        gl:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Association with cardinality violation at the used direction.";
        sh:minCount     1;
        sh:name         "PositionPoint.Location-cardinality";
        sh:order        9;
        sh:path         cim:PositionPoint.Location;
        sh:severity     sh:Violation .

gl:PositionPoint.sequenceNumber-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:integer;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        gl:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "PositionPoint.sequenceNumber-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        5;
        sh:path         cim:PositionPoint.sequenceNumber;
        sh:severity     sh:Violation .

gl:PositionPoint.sequenceNumber-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        gl:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "PositionPoint.sequenceNumber-cardinality";
        sh:order        8;
        sh:path         cim:PositionPoint.sequenceNumber;
        sh:severity     sh:Violation .

gl:PositionPoint.xPosition-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        gl:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "PositionPoint.xPosition-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        4;
        sh:path         cim:PositionPoint.xPosition;
        sh:severity     sh:Violation .

gl:PositionPoint.xPosition-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        gl:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "PositionPoint.xPosition-cardinality";
        sh:order        7;
        sh:path         cim:PositionPoint.xPosition;
        sh:severity     sh:Violation .

gl:PositionPoint.yPosition-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        gl:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "PositionPoint.yPosition-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        3;
        sh:path         cim:PositionPoint.yPosition;
        sh:severity     sh:Violation .

gl:PositionPoint.yPosition-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        gl:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "PositionPoint.yPosition-cardinality";
        sh:order        6;
        sh:path         cim:PositionPoint.yPosition;
        sh:severity     sh:Violation .

gl:PositionPoint.zPosition-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        gl:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "PositionPoint.zPosition-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        2;
        sh:path         cim:PositionPoint.zPosition;
        sh:severity     sh:Violation .

gl:PositionPoint.zPosition-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        gl:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "PositionPoint.zPosition-cardinality";
        sh:order        5;
        sh:path         cim:PositionPoint.zPosition;
        sh:severity     sh:Violation .

gl:PositionPoint-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              gl:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              2;
        sh:property           [ sh:path  cim:PositionPoint.Location ];
        sh:property           [ sh:path  cim:PositionPoint.sequenceNumber ];
        sh:property           [ sh:path  cim:PositionPoint.xPosition ];
        sh:property           [ sh:path  cim:PositionPoint.yPosition ];
        sh:property           [ sh:path  cim:PositionPoint.zPosition ];
        sh:severity           sh:Info;
        sh:targetClass        cim:PositionPoint .

gl:PositionPoint  rdf:type  sh:NodeShape;
        sh:property     gl:PositionPoint.Location-valueType , gl:PositionPoint.Location-cardinality , gl:PositionPoint.sequenceNumber-datatype , gl:PositionPoint.sequenceNumber-cardinality , gl:PositionPoint.xPosition-datatype , gl:PositionPoint.xPosition-cardinality , gl:PositionPoint.yPosition-datatype , gl:PositionPoint.yPosition-cardinality , gl:PositionPoint.zPosition-datatype , gl:PositionPoint.zPosition-cardinality;
        sh:targetClass  cim:PositionPoint .

ido:IdentifiedObject.mRID-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        ido:DatatypesGroupIO;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "IdentifiedObject.mRID-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        0.1;
        sh:path         cim:IdentifiedObject.mRID;
        sh:severity     sh:Violation .

ido:IdentifiedObject.mRID-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        ido:CardinalityIO;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "IdentifiedObject.mRID-cardinality";
        sh:order        0.1;
        sh:path         cim:IdentifiedObject.mRID;
        sh:severity     sh:Violation .

ido:IdentifiedObject.name-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        ido:DatatypesGroupIO;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "IdentifiedObject.name-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        0.1;
        sh:path         cim:IdentifiedObject.name;
        sh:severity     sh:Violation .

ido:IdentifiedObject.name-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        ido:CardinalityIO;
        sh:maxCount     1;
        sh:message      "Cardinality violation. Upper bound shall be 1";
        sh:name         "IdentifiedObject.name-cardinality";
        sh:order        0.1;
        sh:path         cim:IdentifiedObject.name;
        sh:severity     sh:Violation .

gl:CoordinateSystem.crsUrn-datatype
        rdf:type        sh:PropertyShape;
        sh:datatype     xsd:string;
        sh:description  "This constraint validates the datatype of the property (attribute).";
        sh:group        gl:DatatypesGroup;
        sh:message      "The datatype is not literal or it violates the xsd datatype.";
        sh:name         "CoordinateSystem.crsUrn-datatype";
        sh:nodeKind     sh:Literal;
        sh:order        -1;
        sh:path         cim:CoordinateSystem.crsUrn;
        sh:severity     sh:Violation .

gl:CoordinateSystem.crsUrn-cardinality
        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the cardinality of the property (attribute).";
        sh:group        gl:CardinalityGroup;
        sh:maxCount     1;
        sh:message      "Missing required property (attribute).";
        sh:minCount     1;
        sh:name         "CoordinateSystem.crsUrn-cardinality";
        sh:order        2;
        sh:path         cim:CoordinateSystem.crsUrn;
        sh:severity     sh:Violation .

gl:CoordinateSystem.Location-propertyInverse
        rdf:type        sh:PropertyShape;
        sh:description  "Inverse associations shall not be instantiated.";
        sh:group        gl:InverseAssociationsGroup;
        sh:maxCount     0;
        sh:message      "Inverse association is present.";
        sh:name         "InverseAssociationPresent";
        sh:order        1;
        sh:path         cim:CoordinateSystem.Location;
        sh:severity     sh:Violation .

gl:CoordinateSystem.Location-inverseNodePresent
        rdf:type             sh:NodeShape;
        sh:property          gl:CoordinateSystem.Location-propertyInverse;
        sh:targetSubjectsOf  cim:CoordinateSystem.Location .

gl:CoordinateSystem-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              gl:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              1;
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:CoordinateSystem.crsUrn ];
        sh:severity           sh:Info;
        sh:targetClass        cim:CoordinateSystem .

gl:CoordinateSystem  rdf:type  sh:NodeShape;
        sh:property     ido:IdentifiedObject.mRID-datatype , ido:IdentifiedObject.mRID-cardinality , ido:IdentifiedObject.name-datatype , ido:IdentifiedObject.name-cardinality , gl:CoordinateSystem.crsUrn-datatype , gl:CoordinateSystem.crsUrn-cardinality;
        sh:targetClass  cim:CoordinateSystem .

gl:AllowedClasses-property
        rdf:type        sh:PropertyShape;
        sh:description  "Checks if the dataset contains classes which are not defined in the profile to which this dataset conforms to.";
        sh:group        gl:ProfileClassesGroup;
        sh:in           ( cim:CoordinateSystem cim:PositionPoint cim:Location md:FullModel dm:DifferenceModel dcat:Dataset );
        sh:message      "This class is not part of the profile to which this dataset conforms to.";
        sh:name         "ClassNotInProfile";
        sh:order        1;
        sh:path         rdf:type;
        sh:severity     sh:Info .

gl:AllowedClasses-node
        rdf:type             sh:NodeShape;
        sh:property          gl:AllowedClasses-property;
        sh:targetSubjectsOf  rdf:type .

gl:ProfilePropertiesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileProperties";
        sh:order    1 .

gl:AssociationsGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Associations";
        sh:order    2 .

ido:DatatypesGroupIO  rdf:type  sh:PropertyGroup;
        rdfs:label  "DatatypesIO";
        sh:order    1 .

gl:ProfileClassesGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "ProfileClasses";
        sh:order    1 .

gl:InverseAssociationsGroup
        rdf:type    sh:PropertyGroup;
        rdfs:label  "InverseAssociations";
        sh:order    1 .

gl:DatatypesGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Datatypes";
        sh:order    1 .

ido:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "CardinalityIO";
        sh:order    0 .

gl:CardinalityGroup  rdf:type  sh:PropertyGroup;
        rdfs:label  "Cardinality";
        sh:order    0 .

