        rdf:type        sh:PropertyShape;
        sh:description  "This constraint validates the value of the association at the used direction.";
        sh:group        tpbd:AssociationsGroup;
        sh:in           ( cim:EquivalentNetwork cim:DCEquipmentContainer cim:DCConverterUnit cim:DCLine cim:Line cim:Substation cim:VoltageLevel cim:Bay );
