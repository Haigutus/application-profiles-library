tpbd:TopologicalNode-AllowedProperties
        rdf:type              sh:NodeShape;
        sh:closed             true;
        sh:description        "Checks if the dataset contains properties which are not defined in the profile to which this dataset conforms to.";
        sh:group              tpbd:ProfilePropertiesGroup;
        sh:ignoredProperties  ( rdf:type );
        sh:message            "This property is not part of the profile to which this dataset conforms to.";
        sh:name               "PropertyNotInProfile";
        sh:order              1;
        sh:property           [ sh:path  entsoe:TopologicalNode.toEndName ];
        sh:property           [ sh:path  entsoe:TopologicalNode.toEndNameTso ];
        sh:property           [ sh:path  entsoe:TopologicalNode.boundaryPoint ];
        sh:property           [ sh:path  cim:TopologicalNode.BaseVoltage ];
        sh:property           [ sh:path  entsoe:TopologicalNode.toEndIsoCode ];
        sh:property           [ sh:path  entsoe:TopologicalNode.fromEndIsoCode ];
        sh:property           [ sh:path  entsoe:TopologicalNode.fromEndName ];
        sh:property           [ sh:path  cim:TopologicalNode.ConnectivityNodeContainer ];
        sh:property           [ sh:path  entsoe:TopologicalNode.fromEndNameTso ];
        sh:property           [ sh:path  entsoe:IdentifiedObject.shortName ];
        sh:property           [ sh:path  cim:IdentifiedObject.name ];
        sh:property           [ sh:path  cim:IdentifiedObject.mRID ];
        sh:property           [ sh:path  entsoe:IdentifiedObject.energyIdentCodeEic ];
        sh:property           [ sh:path  cim:IdentifiedObject.description ];
        sh:severity           sh:Info;
        sh:targetClass        cim:TopologicalNode .

